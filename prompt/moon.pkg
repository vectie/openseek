import {
  "bobzhang/openseek/deepseek",
}

import {
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/string",
  "moonbitlang/async",
} for "test"

dev_build(
  rule: "md_to_mbt_string",
  input: "base_prompt.mbt.md",
  output: "generated_base_prompt.mbt",
)

dev_build(
  rule: "md_to_mbt_string",
  input: "flash_prompt.mbt.md",
  output: "generated_flash_prompt.mbt",
)

warnings = "+unnecessary_annotation-unused_value-unused_type_declaration-unused_constructor-unused_field-todo-declaration_unimplemented"

supported_targets = "+native"
