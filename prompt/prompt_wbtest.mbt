///|
test "system prompt includes moonbit guide" {
  let prompt = base_prompt()
  assert_true(prompt.contains("# Agent Workflow"))
  assert_true(prompt.contains("MoonBit Error Handling"))
  assert_true(prompt.contains("--warn-list +unnecessary_annotation"))
  assert_true(prompt.contains("moon run -e"))
  assert_false(prompt.contains("moon run -c"))
  assert_true(prompt.contains("Find `moon.mod` (module root)"))
  assert_false(prompt.contains("Find `moon.mod.json` (module root)"))
  assert_true(prompt.contains("Typical Module configuration (`moon.mod`)"))
  assert_false(
    prompt.contains("Typical Module configurations (`moon.mod.json`)"),
  )
  assert_true(prompt.contains("preferred_target = \"native\""))
  assert_false(prompt.contains("\"preferred-target\": \"native\""))
  assert_true(prompt.contains("cache-friendly"))
  assert_true(prompt.contains("moon ide outline"))
  assert_true(prompt.contains("start_line"))
  assert_true(prompt.contains("flat like Go packages"))
  assert_true(prompt.contains("generated native/C entry path"))
  assert_true(prompt.contains("moonbitlang/core/argparse"))
  assert_true(prompt.contains("@argparse.parse(...)"))
  assert_true(prompt.contains("FlagArg(long=\"stdin\")"))
  assert_false(prompt.contains("use `@env.args()` for arguments"))
  assert_true(prompt.contains("@stdio.stdin.read_all().text()"))
  assert_true(prompt.contains("Do not use `/dev/stdin` or C FFI"))
  assert_true(prompt.contains("create `moon.mod`, not `moon.mod.json`"))
  assert_true(prompt.contains("After editing `moon.mod`, `moon.pkg`"))
  assert_true(prompt.contains("acceptance probes"))
  assert_true(prompt.contains("file arguments are read as files"))
  assert_true(prompt.contains("moon check --watch --diagnostic-limit 10"))
  assert_true(prompt.contains("--diagnostic-limit 10"))
  assert_true(prompt.contains("`moon_check` starts or reuses a persistent"))
  assert_true(prompt.contains("Repeated `moon_check` calls are allowed"))
  assert_true(prompt.contains("automatically starts a replacement watcher"))
  assert_true(prompt.contains("Moon command quick reference"))
  assert_true(prompt.contains("moon test parser --filter \"Parser::*\""))
  assert_true(prompt.contains("moon run --target native cmd/tomljson"))
  assert_true(
    prompt.contains("moon run --target native -e 'fn main { println(\"ok\") }'"),
  )
  assert_true(prompt.contains("moon cram test tests/cram"))
  assert_true(prompt.contains("mooncram"))
  assert_true(prompt.contains("shell `moon ide doc`"))
  assert_true(prompt.contains("moon ide doc \"StringView::split\""))
  assert_true(prompt.contains("moon ide doc \"@json.parse\""))
  assert_true(prompt.contains("for package functions"))
  assert_true(prompt.contains("not broad English terms or full package paths"))
  assert_true(prompt.contains("moon ide peek-def parse --loc"))
  assert_true(prompt.contains("moon fmt --check parser"))
  assert_true(prompt.contains("moon coverage analyze --package"))
  assert_false(prompt.contains("check_daemon"))
  assert_false(prompt.contains("moon_ide"))
  assert_false(prompt.contains("moon_cmd"))
  assert_true(prompt.contains("OpenSeek DeepSeek Addendum"))
  assert_false(prompt.contains("try?"))
  assert_false(prompt.contains("try!"))
}

///|
test "flash prompt includes flash addenda" {
  let prompt = flash_prompt()
  assert_true(prompt.contains("DeepSeek V4 Flash"))
  assert_true(prompt.contains("Do not emit JSON action plans"))
  assert_true(prompt.contains("moon check --watch --diagnostic-limit 10"))
  assert_true(prompt.contains("--diagnostic-limit 10"))
  assert_true(prompt.contains("Use `moon_check` once near the start"))
  assert_true(prompt.contains("Repeated\n  `moon_check` calls are allowed"))
  assert_true(prompt.contains("restarts crashed\n  watchers automatically"))
  assert_true(prompt.contains("Common `moon` subcommands"))
  assert_true(prompt.contains("shell `moon test`"))
  assert_true(prompt.contains("moon test parser --filter \"Parser::*\""))
  assert_true(prompt.contains("shell `moon run`"))
  assert_true(prompt.contains("moon run --target native cmd/tomljson"))
  assert_true(prompt.contains("shell `moon info`"))
  assert_true(prompt.contains("shell `moon fmt`"))
  assert_true(prompt.contains("moon fmt --check parser"))
  assert_true(prompt.contains("shell `moon doc` and `moon explain`"))
  assert_true(prompt.contains("shell `moon ide doc`"))
  assert_true(prompt.contains("moon ide doc \"StringView::split\""))
  assert_true(prompt.contains("moon ide doc \"@json.parse\""))
  assert_true(prompt.contains("for package functions"))
  assert_true(prompt.contains("not broad English terms"))
  assert_true(prompt.contains("shell `moon coverage analyze`"))
  assert_true(prompt.contains("moon coverage analyze --package"))
  assert_true(prompt.contains("moon cram test tests/cram"))
  assert_true(prompt.contains("mooncram"))
  assert_true(prompt.contains("moon ide peek-def parse --loc"))
  assert_true(prompt.contains("moon run --target native - <<'EOF'"))
  assert_false(prompt.contains("check_daemon"))
  assert_false(prompt.contains("moon_ide"))
  assert_false(prompt.contains("moon_cmd"))
  assert_true(prompt.contains("moon run -e"))
  assert_true(prompt.contains("Do not use `moon run -c`"))
  assert_true(prompt.contains("Do not run\n  `moon run -e`"))
  assert_true(prompt.contains("send the code on stdin"))
  assert_true(prompt.contains("snippets may include an `import` block"))
  assert_true(prompt.contains("moon run --target native -e"))
  assert_true(prompt.contains("\"moonbitlang/async@0.19.1\""))
  assert_true(prompt.contains("@stdio.stdout.write(data)"))
  assert_true(prompt.contains("Current MoonBit modules use `moon.mod`"))
  assert_true(prompt.contains("moon.mod.json` is legacy"))
  assert_true(
    prompt.contains("Import local packages by their full package path"),
  )
  assert_true(prompt.contains("\"user/toml/lib\""))
  assert_true(prompt.contains("@lib.parse(...)"))
  assert_true(prompt.contains("Do not import `moonbitlang/core`"))
  assert_true(prompt.contains("moonbitlang/core/argparse"))
  assert_true(prompt.contains("@argparse.parse("))
  assert_true(prompt.contains("Command("))
  assert_true(prompt.contains("struct Config"))
  assert_false(prompt.contains("fn cli_command() -> @argparse.Command"))
  assert_true(prompt.contains("fn config_from_matches"))
  assert_true(prompt.contains("values: { \"input\"?: Some([input, ..]), .. }"))
  assert_true(prompt.contains("flags: { \"stdin\"?: Some(stdin), .. }"))
  assert_true(prompt.contains("flags: { \"stdin\"?: None, .. }"))
  assert_true(prompt.contains("Some([input, ..])"))
  assert_false(prompt.contains("matches.values.get(\"input\")"))
  assert_false(prompt.contains("values.length() > 0"))
  assert_false(prompt.contains("fn value(matches : @argparse.Matches"))
  assert_false(prompt.contains("fn flag(matches : @argparse.Matches"))
  assert_true(prompt.contains("@string.from_str"))
  assert_true(prompt.contains("not write `@string.from_str[:Int](text)`"))
  assert_true(prompt.contains("inspect(n, content=\"123\")"))
  assert_true(prompt.contains("In success tests, call raising functions"))
  assert_true(prompt.contains("fails with the error"))
  assert_true(prompt.contains("Use checked errors for ordinary parser"))
  assert_true(prompt.contains("Declare ordinary failing helpers"))
  assert_true(prompt.contains("Think of `raise` as a checked effect"))
  assert_true(prompt.contains("different from unchecked exceptions"))
  assert_true(prompt.contains("different from ordinary error\n  return values"))
  assert_true(prompt.contains("less plumbing"))
  assert_true(prompt.contains("success-path code direct"))
  assert_true(
    prompt.contains("Let errors travel through internal parser layers"),
  )
  assert_true(prompt.contains("For rare typed-error APIs"))
  assert_true(prompt.contains("raise ParseError` may only let `ParseError`"))
  assert_true(prompt.contains("catch that error and translate it"))
  assert_true(prompt.contains("Do not wrap successful\n  parser tests"))
  assert_true(prompt.contains("wrap raising calls in a manual success/failure"))
  assert_true(prompt.contains("prefer a CLI acceptance probe"))
  assert_true(prompt.contains("suberror ParseError"))
  assert_true(
    prompt.contains("fn parse_count(text : String) -> Int raise ParseError"),
  )
  assert_true(prompt.contains("fn main raise"))
  assert_true(prompt.contains("async fn` can raise by default"))
  assert_true(prompt.contains("Do not write `async fn main raise`"))
  assert_true(prompt.contains("async fn helper() -> Unit noraise"))
  assert_true(prompt.contains("do not encode failure as `Json::null`, `()`"))
  assert_true(prompt.contains("For custom errors, use `suberror`"))
  assert_false(
    prompt.contains(
      "Prelude types such as `Array`,\n  `Map`, `Json`, `StringBuilder`, `Result`",
    ),
  )
  assert_false(prompt.contains("Result"))
  assert_false(prompt.contains("Ok("))
  assert_false(prompt.contains("Err("))
  assert_false(prompt.contains("prefer `Result[T, String]`"))
  assert_false(
    prompt.contains("Prefer checked errors over `Result[T, String]`"),
  )
  assert_false(prompt.contains("When an API returns `Result[...]`"))
  assert_false(prompt.contains("errors prefer `Err(\"message\")`"))
  assert_false(prompt.contains("let result : Result[Int, Error]"))
  assert_false(prompt.contains("try?"))
  assert_false(prompt.contains("try!"))
  assert_false(prompt.contains("raise Failure::Failure"))
  assert_false(prompt.contains("@string.parse_int"))
  assert_true(
    prompt.contains("Json::number(n.to_double(), repr=text.to_owned())"),
  )
  assert_true(prompt.contains("json.stringify()"))
  assert_true(prompt.contains("moonbitlang/async/fs"))
  assert_true(prompt.contains("FlagArg.long` omits leading dashes"))
  assert_true(prompt.contains("not\n  `long=\"--stdin\"`"))
  assert_true(prompt.contains("@stdio.stdin.read_all().text()"))
  assert_true(prompt.contains("@fs.read_file(config.input).text()"))
  assert_true(prompt.contains("Json::object(map)"))
  assert_true(prompt.contains("Json::boolean(b)"))
  assert_true(prompt.contains("Empty no-op expression is `()`"))
  assert_true(prompt.contains("Do not write `\\(expr)`"))
  assert_true(prompt.contains("$|error: \\{name}"))
  assert_true(prompt.contains("$|line: \\{line}"))
  assert_true(
    prompt.contains("Do not implement ordinary file/stdin IO with C FFI"),
  )
  assert_true(
    prompt.contains("moon run --target native cmd/tomljson -- /tmp/input.toml"),
  )
  assert_true(prompt.contains("not\n  `/dev/stdin` or C FFI"))
  assert_false(prompt.contains("Spec-driven Development"))
  assert_false(prompt.contains("proof_invariant"))
  assert_false(prompt.contains("Loop Invariants"))
}

///|
test "default prompt is selected per model" {
  assert_eq(system_prompt_for_model(V4Flash), flash_prompt())
  assert_true(system_prompt_for_model(V4Flash).contains("DeepSeek V4 Flash"))
  assert_false(system_prompt_for_model(V4Pro).contains("DeepSeek V4 Flash"))
}
