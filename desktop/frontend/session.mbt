///|
/// Generate a fresh conversation session id and feed it back through
/// `SessionRotated`. Issued at startup and again by "New chat", so the model
/// never reads the clock directly.
fn rotate_session(dispatch : @cmd.Emit[Msg]) -> @cmd.Cmd {
  @cmd.custom_cmd(scheduler => {
    scheduler.add(dispatch(SessionRotated(generated_session_id())))
  })
}

///|
/// Session ids generated by the desktop client: a UTC wall-clock stamp,
/// `desktop-YYYYMMDD-HHMMSS-mmm-sssssssss`, mirroring the TUI's `tui-...` form
/// with a random salt so two windows rotating in the same millisecond still get
/// separate conversations.
fn generated_session_id() -> String {
  let date_constructor : @js.Value = @js.globalThis.get_with_string("Date")
  let now : @js.Value = date_constructor.new(([] : Array[@js.Value]))
  fn utc(name : String) -> Int {
    now.apply_with_string(name, ([] : Array[@js.Value]))
  }

  let date = pad(utc("getUTCFullYear"), 4) +
    pad(utc("getUTCMonth") + 1, 2) +
    pad(utc("getUTCDate"), 2)
  let time = pad(utc("getUTCHours"), 2) +
    pad(utc("getUTCMinutes"), 2) +
    pad(utc("getUTCSeconds"), 2)
  "desktop-\{date}-\{time}-\{pad(utc("getUTCMilliseconds"), 3)}-\{random_salt()}"
}

///|
fn random_salt() -> String {
  let math : @js.Value = @js.globalThis.get_with_string("Math")
  let value : Double = math.apply_with_string("random", ([] : Array[@js.Value]))
  pad((value * 1_000_000_000.0).to_int(), 9)
}

///|
fn pad(value : Int, width : Int) -> String {
  let mut text = value.to_string()
  while text.length() < width {
    text = "0\{text}"
  }
  text
}
