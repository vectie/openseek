  "moonbitlang/core/string",
} for "wbtest"

warnings = "+test_unqualified_package+unnecessary_annotation+unnecessary_view_op+ambiguous_range_direction+unqualified_local_using"

supported_targets = "native"

options(
  "is-main": true,
)
