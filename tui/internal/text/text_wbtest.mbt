///|
test "truncate line respects display width and graphemes" {
  inspect(truncate_line("abcdef", 3), content="abвҖҰ")
  inspect(truncate_line("abcdef", 5), content="abcdвҖҰ")
  inspect(truncate_line("abc", 3), content="abc")
  inspect(truncate_line("дҪ еҘҪдё–з•Ң", 5), content="дҪ еҘҪвҖҰ")
  inspect(
    truncate_line("xрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұyz", 4),
    content="xрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘ҰвҖҰ",
  )
  inspect(truncate_line("abcdef", 1), content="вҖҰ")
}

///|
test "split lines keeps trailing input row" {
  inspect(split_lines("a\nb\n").join("|"), content="a|b|")
}
