///|
/// A function tool definition accepted by the DeepSeek chat completions API.
///
/// `parameters` is a JSON Schema object describing the arguments the model may
/// generate for this function.
pub struct FunctionTool {
  name : String
  description : String
  parameters : Json
  strict : Bool
} derive(Debug)

///|
/// Constructs a typed DeepSeek function tool definition.
pub fn FunctionTool::FunctionTool(
  name : String,
  description : String,
  parameters : Json,
  strict? : Bool = false,
) -> FunctionTool {
  { name, description, parameters, strict }
}

///|
/// A tool call generated by a DeepSeek assistant response.
///
/// `arguments` is the raw JSON string returned by DeepSeek and should be parsed
/// and validated by the caller before executing a local function.
pub struct ToolCall {
  /// The DeepSeek-generated tool call id. Use it as the `tool_call_id` when
  /// sending the corresponding `Tool(id)` result message back to the API.
  id : String
  /// The function name requested by the model, matching one of the provided
  /// `FunctionTool.name` values.
  name : String
  /// The raw JSON argument string returned by DeepSeek for this function call.
  /// Parse and validate it before executing a local tool.
  arguments : String
} derive(Debug)

///|
/// Constructs a typed DeepSeek tool call value.
pub fn ToolCall::ToolCall(
  id~ : String,
  name~ : String,
  arguments~ : String,
) -> ToolCall {
  { id, name, arguments }
}
