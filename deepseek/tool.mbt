///|
/// A tool definition accepted by the DeepSeek chat completions API.
///
/// `ToolDefinition` is the tool contract the client sends in the request
/// `tools` field before the model chooses a tool. It advertises what local
/// function exists, what it does, and what JSON Schema its arguments must
/// follow. It is not a request to execute the function.
///
/// `parameters` is a JSON Schema object describing the arguments the model may
/// generate for this function.
pub struct ToolDefinition {
  /// The function name exposed to the model. A later `ToolCall.name` should
  /// match one of these names.
  name : String
  /// Human-readable guidance for when and how the model should use the tool.
  description : String
  /// JSON Schema for the arguments the model should generate when it calls this
  /// function.
  parameters : Json
  /// Whether DeepSeek should enforce strict schema adherence for this function.
  strict : Bool
} derive(Debug)

///|
/// Constructs a typed DeepSeek tool definition.
pub fn ToolDefinition::ToolDefinition(
  name : String,
  description : String,
  parameters : Json,
  strict? : Bool = false,
) -> ToolDefinition {
  { name, description, parameters, strict }
}

///|
/// A tool call generated by a DeepSeek assistant response.
///
/// `ToolCall` is the model's request to execute one previously advertised
/// `ToolDefinition`. It appears in `ChatResponse.tool_calls` and is echoed back
/// in an assistant `ChatMessage(Assistant, "", tool_calls=[...])` before
/// sending the actual tool result as `ChatMessage(Tool(call.id), result)`.
///
/// `arguments` is the raw JSON string returned by DeepSeek and should be parsed
/// and validated by the caller before executing a local function.
pub struct ToolCall {
  /// The DeepSeek-generated tool call id. Use it as the `tool_call_id` when
  /// sending the corresponding `Tool(id)` result message back to the API.
  id : String
  /// The function name requested by the model, matching one of the provided
  /// `ToolDefinition.name` values.
  name : String
  /// The raw JSON argument string returned by DeepSeek for this function call.
  /// Parse and validate it before executing a local tool.
  arguments : String
} derive(Debug)

///|
/// Constructs a typed DeepSeek tool call value.
pub fn ToolCall::ToolCall(
  id~ : String,
  name~ : String,
  arguments~ : String,
) -> ToolCall {
  { id, name, arguments }
}
